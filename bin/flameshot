#!/bin/bash

options=("$@")

# Detecta se a sessão atual é Wayland
IS_WAYLAND=false
if [ "$XDG_SESSION_TYPE" == "wayland" ]; then
    IS_WAYLAND=true
fi

if [ -f /usr/bin/flameshot ]; then
    # Se for Wayland, aplica as variáveis antes de rodar a versão nativa
    if [ "$IS_WAYLAND" = true ]; then
        export QT_QPA_PLATFORM=wayland
        export QT_SCREEN_SCALE_FACTORS="1;1"
    fi
    /usr/bin/flameshot "${options[@]}"
else
    # Lógica do Flatpak
    if ! flatpak permissions | grep "org.flameshot.Flameshot" | grep -q "background.*yes"; then
        flatpak permission-set background background org.flameshot.Flameshot yes
    fi
    if ! flatpak permissions | grep "org.flameshot.Flameshot" | grep -q "screenshot.*yes"; then
        flatpak permission-set screenshot screenshot org.flameshot.Flameshot yes
    fi

    # Se for Wayland, adiciona os envs no comando do Flatpak
    if [ "$IS_WAYLAND" = true ]; then
        flatpak run --env=QT_QPA_PLATFORM=wayland --env=QT_SCREEN_SCALE_FACTORS="1;1" \
        org.flameshot.Flameshot "${options[@]}"
    else
        flatpak run org.flameshot.Flameshot "${options[@]}"
    fi
fi
